    // gain3(g) = *(g),*(g),*(g);
    // gain4(g) = *(g),*(g),*(g),*(g);
    // gain5(g) = *(g),*(g),*(g),*(g),*(g);
    // gain6(g) = *(g),*(g),*(g),*(g),*(g),*(g);
    // gain7(g) = *(g),*(g),*(g),*(g),*(g),*(g),*(g);
